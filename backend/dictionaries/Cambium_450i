# DICCIONARIO RADIUS PARA CAMBIUM PMP 450i / CANOPY
# Basado en Vendor ID 161 (Legacy Motorola/Canopy)
# NOTA: Usamos ID 50 que es el estándar para Cambium PMP 450i (Vendor ID 161)

VENDOR      Motorola    161

BEGIN-VENDOR    Motorola

# --- Gestión de Usuarios (Acceso al AP) ---
# Nivel de usuario: 1=Tech, 2=Install, 3=Admin [Fuente 209]
ATTRIBUTE   Motorola-Cambium-Canopy-UserLevel     50  integer
# Modo de usuario: 0=Read-Write, 1=Read-Only [Fuente 209]
ATTRIBUTE   Motorola-Cambium-Canopy-UserMode      51  integer

# --- Gestión de Ancho de Banda (QoS) ---
# Velocidades Sostenidas (Sustained Rates) en kbps [Fuente 213]
ATTRIBUTE   Motorola-Cambium-Canopy-DLBR          8   integer
ATTRIBUTE   Motorola-Cambium-Canopy-ULBR          7   integer

# Ráfagas (Burst Allocation) en kbits [Fuente 213]
ATTRIBUTE   Motorola-Cambium-Canopy-DLBL          6   integer
ATTRIBUTE   Motorola-Cambium-Canopy-ULBL          5   integer

# --- Configuración de Prioridad (VoIP/High Priority) ---
# Habilitar canal de alta prioridad: 1=Enable, 0=Disable [Fuente 213]
ATTRIBUTE   Motorola-Cambium-Canopy-HPENABLE     24   integer
ATTRIBUTE   Motorola-Cambium-Canopy-HPDLCIR      22   integer
ATTRIBUTE   Motorola-Cambium-Canopy-HPULCIR      23   integer
ATTRIBUTE   Motorola-Cambium-Canopy-LPDLCIR      20   integer
ATTRIBUTE   Motorola-Cambium-Canopy-LPULCIR      21   integer

# --- Configuración de Red Específica ---
# Gateway para el SM (si se asigna IP estática/Framed-IP) [Fuente 212]
ATTRIBUTE   Motorola-Cambium-Canopy-Gateway      4    ipaddr

# --- VLANs ---
# Habilitar aprendizaje de VLAN [Fuente 214]
ATTRIBUTE   Motorola-Cambium-Canopy-VLLEARNEN     14   integer
# ID de VLAN (1-4094) [Fuente 214]
ATTRIBUTE   Motorola-Cambium-Canopy-VLIDSET      15   integer

# --- Otros Atributos de Broadcast ---
ATTRIBUTE   Motorola-Cambium-Canopy-BCASTMIR      25   integer

END-VENDOR      Motorola