import pytest
from httpx import AsyncClient

pytestmark = pytest.mark.asyncio


async def test_create_nas_category_superadmin(
    async_client: AsyncClient, superadmin_token: str
):
    headers = {"Authorization": f"Bearer {superadmin_token}"}
    payload = {
        "name": "Superadmin Category",
        "description": "Created by superadmin",
        "criticality": "high",
    }
    response = await async_client.post(
        "/nas-categories", json=payload, headers=headers
    )
    assert response.status_code == 201
    data = response.json()
    assert data["name"] == "Superadmin Category"
    assert data["criticality"] == "high"
    assert "id" in data


async def test_create_nas_category_admin(async_client: AsyncClient, admin_token: str):
    headers = {"Authorization": f"Bearer {admin_token}"}
    payload = {
        "name": "Admin Category",
        "description": "Created by admin",
        "criticality": "medium",
    }
    response = await async_client.post(
        "/nas-categories", json=payload, headers=headers
    )
    assert response.status_code == 201
    data = response.json()
    assert data["name"] == "Admin Category"


async def test_create_nas_category_invalid_criticality(
    async_client: AsyncClient, superadmin_token: str
):
    headers = {"Authorization": f"Bearer {superadmin_token}"}
    payload = {
        "name": "Invalid Crit",
        "criticality": "super-high",  # Should be low, medium, or high
    }
    response = await async_client.post(
        "/nas-categories", json=payload, headers=headers
    )
    assert response.status_code == 422  # Pydantic validation error


async def test_create_nas_category_unauthorized_roles(
    async_client: AsyncClient,
    helpdesk_token: str,
    auditor_token: str,
    readonly_token: str,
):
    payload = {"name": "Hacker Category", "criticality": "low"}

    for token in [helpdesk_token, auditor_token, readonly_token]:
        headers = {"Authorization": f"Bearer {token}"}
        response = await async_client.post(
            "/nas-categories", json=payload, headers=headers
        )
        assert response.status_code == 403


async def test_get_nas_categories(
    async_client: AsyncClient, superadmin_token: str, readonly_token: str
):
    # Setup - Create one category
    headers_sa = {"Authorization": f"Bearer {superadmin_token}"}
    await async_client.post(
        "/nas-categories",
        json={"name": "Get Category", "criticality": "low"},
        headers=headers_sa,
    )

    # Any valid user can read
    headers_ro = {"Authorization": f"Bearer {readonly_token}"}
    response = await async_client.get("/nas-categories", headers=headers_ro)
    assert response.status_code == 200
    data = response.json()
    assert isinstance(data, list)
    assert any(cat["name"] == "Get Category" for cat in data)


async def test_get_nas_category_by_id(async_client: AsyncClient, superadmin_token: str):
    headers = {"Authorization": f"Bearer {superadmin_token}"}
    create_resp = await async_client.post(
        "/nas-categories",
        json={"name": "By ID", "criticality": "medium"},
        headers=headers,
    )
    cat_id = create_resp.json()["id"]

    response = await async_client.get(f"/nas-categories/{cat_id}", headers=headers)
    assert response.status_code == 200
    assert response.json()["name"] == "By ID"


async def test_get_nas_category_not_found(
    async_client: AsyncClient, superadmin_token: str
):
    headers = {"Authorization": f"Bearer {superadmin_token}"}
    response = await async_client.get("/nas-categories/99999", headers=headers)
    assert response.status_code == 404


async def test_delete_nas_category(
    async_client: AsyncClient, superadmin_token: str, admin_token: str
):
    headers_sa = {"Authorization": f"Bearer {superadmin_token}"}
    headers_admin = {"Authorization": f"Bearer {admin_token}"}

    # Create category
    create_resp = await async_client.post(
        "/nas-categories",
        json={"name": "To Delete", "criticality": "low"},
        headers=headers_sa,
    )
    cat_id = create_resp.json()["id"]

    # Delete with admin
    delete_resp = await async_client.delete(
        f"/nas-categories/{cat_id}", headers=headers_admin
    )
    assert delete_resp.status_code == 204

    # Verify deleted
    get_resp = await async_client.get(
        f"/nas-categories/{cat_id}", headers=headers_sa
    )
    assert get_resp.status_code == 404


async def test_delete_nas_category_unauthorized(
    async_client: AsyncClient, superadmin_token: str, helpdesk_token: str
):
    headers_sa = {"Authorization": f"Bearer {superadmin_token}"}

    # Create category
    create_resp = await async_client.post(
        "/nas-categories",
        json={"name": "Safe Category", "criticality": "high"},
        headers=headers_sa,
    )
    cat_id = create_resp.json()["id"]

    # Try to delete with helpdesk
    headers_hd = {"Authorization": f"Bearer {helpdesk_token}"}
    delete_resp = await async_client.delete(
        f"/nas-categories/{cat_id}", headers=headers_hd
    )
    assert delete_resp.status_code == 403

    # Cleanup
    await async_client.delete(f"/nas-categories/{cat_id}", headers=headers_sa)
