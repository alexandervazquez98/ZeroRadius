# ZeroRadius — Environment Configuration Example
# Copy this file to .env and fill in the values before starting the application.
# cp .env.example .env

# ---------------------------------------------------------------------------
# Database Credentials
# ---------------------------------------------------------------------------
MYSQL_ROOT_PASSWORD=your-root-password-here
MYSQL_DATABASE=radius
MYSQL_USER=radius
MYSQL_PASSWORD=your-radius-db-password-here

# ---------------------------------------------------------------------------
# RADIUS Server
# ---------------------------------------------------------------------------
RADIUS_SECRET=your-radius-shared-secret-here

# ---------------------------------------------------------------------------
# Security
# ---------------------------------------------------------------------------

# REQUIRED — The application will CRASH at startup if SECRET_KEY is not set.
# Generate a strong random secret with:
#   openssl rand -hex 32
# Minimum recommended length: 32 characters.
SECRET_KEY=your-strong-random-secret-here-minimum-32-chars

# JWT signing algorithm. Default is HS256.
# Supported symmetric values: HS256, HS384, HS512
# Asymmetric (RS256/RS512) requires a key pair — see documentation.
ALGORITHM=HS256

# Access token lifetime in minutes. Default is 30.
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Comma-separated list of allowed CORS origins.
# In development, localhost origins are used as fallback when this is not set.
# In production, set this to your actual frontend URL(s).
# Example (development): http://localhost:3009,http://localhost:5173
# Example (production):  https://yourdomain.com
ALLOWED_ORIGINS=http://localhost:3009,http://localhost:5173

# ---------------------------------------------------------------------------
# API Documentation
# ---------------------------------------------------------------------------

# Set to 'true' to disable Swagger/ReDoc in production
DISABLE_DOCS=true
