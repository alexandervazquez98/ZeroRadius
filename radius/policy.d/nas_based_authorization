# NAS-Based Authorization Policy — nas-categories update
# ISO 27001:2022 A.8.3 — Access control based on NAS identity
#
# Three-step authorization:
#
#   Step 1 (IP-specific, unchanged):
#     Query access_policy_assignments by exact NAS-IP-Address.
#     Most specific — always wins over category.
#
#   Step 2 (Segment base):
#     Match NAS-IP against segment CIDR without exception range.
#
#   Step 3 (Category fallback):
#     If no IP match, resolve the NAS device's category via the
#     nas_cidr_ranges VIEW (handles both /32 and CIDR ranges).
#     Then look up the user's category-level privilege mapping.
#
# Reject if neither step finds a match (Zero Trust).
#
# Include this in your authorize {} section:
#   authorize {
#     ...
#     nas_based_authorization
#     ...
#   }

nas_based_authorization {

    if (&NAS-IP-Address) {
        update control {
            Tmp-String-1 := "unmatched"
            Tmp-String-2 := "manual"
        }

        # ── STEP 1: Exact MAC, Exact IP or IP Range Exception ───────────────
        # Priority: MAC+IP > MAC > IP > Range Exception
        # MACs are normalized to lowercase without separators in DB.
        update control {
            Tmp-String-0 := "%{sql:SELECT unpm.radius_group FROM access_policy_assignments unpm \
                LEFT JOIN network_segments ns ON unpm.segment_id = ns.id \
                WHERE unpm.username='%{User-Name}' \
                AND unpm.is_active=1 \
                AND ( \
                    (unpm.calling_station_id IS NOT NULL AND unpm.calling_station_id=LOWER(REPLACE(REPLACE(REPLACE('%{Calling-Station-Id}', '-', ''), ':', ''), '.', ''))) \
                    OR (unpm.nas_ip='%{NAS-IP-Address}' AND unpm.calling_station_id IS NULL) \
                    OR (unpm.segment_id IS NOT NULL AND unpm.calling_station_id IS NULL \
                        AND unpm.target_start_ip IS NOT NULL AND unpm.target_end_ip IS NOT NULL \
                        AND ns.id IS NOT NULL \
                        AND INET_ATON(unpm.target_start_ip) BETWEEN \
                            INET_ATON(SUBSTRING_INDEX(ns.cidr, '/', 1)) AND \
                            INET_ATON(SUBSTRING_INDEX(ns.cidr, '/', 1)) + POW(2, 32 - CAST( \
                                CASE WHEN LOCATE('/', ns.cidr) > 0 THEN SUBSTRING_INDEX(ns.cidr, '/', -1) ELSE '32' END \
                            AS UNSIGNED)) - 1 \
                        AND INET_ATON(unpm.target_end_ip) BETWEEN \
                            INET_ATON(SUBSTRING_INDEX(ns.cidr, '/', 1)) AND \
                            INET_ATON(SUBSTRING_INDEX(ns.cidr, '/', 1)) + POW(2, 32 - CAST( \
                                CASE WHEN LOCATE('/', ns.cidr) > 0 THEN SUBSTRING_INDEX(ns.cidr, '/', -1) ELSE '32' END \
                            AS UNSIGNED)) - 1 \
                        AND INET_ATON('%{NAS-IP-Address}') BETWEEN INET_ATON(unpm.target_start_ip) AND INET_ATON(unpm.target_end_ip)) \
                ) \
                ORDER BY \
                    CASE \
                        WHEN unpm.calling_station_id IS NOT NULL AND unpm.calling_station_id=LOWER(REPLACE(REPLACE(REPLACE('%{Calling-Station-Id}', '-', ''), ':', ''), '.', '')) AND unpm.nas_ip='%{NAS-IP-Address}' THEN 0 \
                        WHEN unpm.calling_station_id IS NOT NULL AND unpm.calling_station_id=LOWER(REPLACE(REPLACE(REPLACE('%{Calling-Station-Id}', '-', ''), ':', ''), '.', '')) THEN 1 \
                        WHEN unpm.nas_ip='%{NAS-IP-Address}' THEN 2 \
                        ELSE 3 \
                    END ASC, \
                    CASE \
                        WHEN unpm.target_start_ip IS NOT NULL AND unpm.target_end_ip IS NOT NULL \
                        THEN INET_ATON(unpm.target_end_ip) - INET_ATON(unpm.target_start_ip) \
                        ELSE 4294967295 \
                    END ASC, \
                    unpm.target_start_ip ASC, \
                    unpm.target_end_ip ASC, \
                    unpm.id ASC \
                LIMIT 1}"
        }

        if ("%{control:Tmp-String-0}" != "") {
            update control {
                Tmp-String-1 := "step1"
            }
        }

        if ("%{control:Tmp-String-0}" == "") {
            # ── STEP 2: Segment Base match ──────────────────────────────────
            # Look for a mapping to a network segment where the NAS IP is inside the segment's CIDR
            update control {
                Tmp-String-0 := "%{sql:SELECT unpm.radius_group \
                    FROM access_policy_assignments unpm \
                    JOIN network_segments ns ON unpm.segment_id = ns.id \
                     WHERE unpm.username='%{User-Name}' \
                     AND unpm.is_active=1 \
                     AND unpm.calling_station_id IS NULL \
                     AND unpm.target_start_ip IS NULL AND unpm.target_end_ip IS NULL \
                     AND INET_ATON('%{NAS-IP-Address}') BETWEEN \
                         INET_ATON(SUBSTRING_INDEX(ns.cidr, '/', 1)) AND \
                         INET_ATON(SUBSTRING_INDEX(ns.cidr, '/', 1)) + POW(2, 32 - CAST( \
                             CASE WHEN LOCATE('/', ns.cidr) > 0 THEN SUBSTRING_INDEX(ns.cidr, '/', -1) ELSE '32' END \
                         AS UNSIGNED)) - 1 \
                     ORDER BY CAST( \
                         CASE WHEN LOCATE('/', ns.cidr) > 0 THEN SUBSTRING_INDEX(ns.cidr, '/', -1) ELSE '32' END \
                     AS UNSIGNED) DESC, ns.id ASC, unpm.id ASC \
                      LIMIT 1}"
            }

            if ("%{control:Tmp-String-0}" != "") {
                update control {
                    Tmp-String-1 := "step2"
                }
            }
        }

        if ("%{control:Tmp-String-0}" == "") {
            # ── STEP 3: Category fallback ───────────────────────────────
            # Resolve the category of the NAS device from the nas_cidr_ranges
            # view, then match the user's category-level privilege mapping.
            update control {
                Tmp-String-0 := "%{sql:SELECT unpm.radius_group \
                    FROM access_policy_assignments unpm \
                    WHERE unpm.username='%{User-Name}' \
                    AND unpm.nas_ip IS NULL \
                    AND unpm.segment_id IS NULL \
                    AND unpm.is_active=1 \
                    AND unpm.nas_category_id = ( \
                        SELECT category_id FROM nas_cidr_ranges \
                        WHERE INET_ATON('%{NAS-IP-Address}') BETWEEN net_start AND net_end \
                        ORDER BY prefix_len DESC LIMIT 1 \
                    ) \
                    LIMIT 1}"
            }

            if ("%{control:Tmp-String-0}" != "") {
                update control {
                    Tmp-String-1 := "step3"
                }
            }
        }

        if ("%{control:Tmp-String-0}" != "") {
            # Match found in one of the steps — apply group
            update control {
                SQL-Group := "%{control:Tmp-String-0}"
            }

            # Transitional toggle (Phase 2 prep)
            # - no/empty (default): keep legacy manual hydration for baseline safety.
            # - yes: skip manual hydration and rely on the following `-sql` in authorize{}
            #        to hydrate radgroupcheck/radgroupreply natively using SQL-Group.
            if ("%{tolower:%{ENV:ZR_RADIUS_NATIVE_GROUP_HYDRATION}}" == "yes") {
                update control {
                    Tmp-String-2 := "native"
                }
            }
            else {
                update control {
                    Tmp-String-2 := "manual"
                }

                # Legacy manual hydration fallback (to preserve current baseline behavior)
                update reply {
                    Reply-Message := "%{sql:SELECT CAST(value AS CHAR) FROM radgroupreply WHERE groupname='%{control:SQL-Group}' AND attribute='Reply-Message' ORDER BY id LIMIT 1}"
                }

                if ("%{sql:SELECT CAST(value AS CHAR) FROM radgroupreply WHERE groupname='%{control:SQL-Group}' AND attribute='Motorola-Cambium-Canopy-UserLevel' ORDER BY id LIMIT 1}" != "") {
                    update reply {
                        Motorola-Cambium-Canopy-UserLevel := "%{sql:SELECT CAST(value AS CHAR) FROM radgroupreply WHERE groupname='%{control:SQL-Group}' AND attribute='Motorola-Cambium-Canopy-UserLevel' ORDER BY id LIMIT 1}"
                    }
                }

                if ("%{sql:SELECT CAST(value AS CHAR) FROM radgroupreply WHERE groupname='%{control:SQL-Group}' AND attribute='Cambium-Canopy-UserLevel' ORDER BY id LIMIT 1}" != "") {
                    update reply {
                        Cambium-Canopy-UserLevel := "%{sql:SELECT CAST(value AS CHAR) FROM radgroupreply WHERE groupname='%{control:SQL-Group}' AND attribute='Cambium-Canopy-UserLevel' ORDER BY id LIMIT 1}"
                    }
                }

                if ("%{sql:SELECT CAST(value AS CHAR) FROM radgroupreply WHERE groupname='%{control:SQL-Group}' AND attribute='Cambium-Canopy-HPDLCIR' ORDER BY id LIMIT 1}" != "") {
                    update reply {
                        Cambium-Canopy-HPDLCIR := "%{sql:SELECT CAST(value AS CHAR) FROM radgroupreply WHERE groupname='%{control:SQL-Group}' AND attribute='Cambium-Canopy-HPDLCIR' ORDER BY id LIMIT 1}"
                    }
                }

                if ("%{sql:SELECT CAST(value AS CHAR) FROM radgroupreply WHERE groupname='%{control:SQL-Group}' AND attribute='Cambium-Canopy-HPULCIR' ORDER BY id LIMIT 1}" != "") {
                    update reply {
                        Cambium-Canopy-HPULCIR := "%{sql:SELECT CAST(value AS CHAR) FROM radgroupreply WHERE groupname='%{control:SQL-Group}' AND attribute='Cambium-Canopy-HPULCIR' ORDER BY id LIMIT 1}"
                    }
                }

                if ("%{sql:SELECT CAST(value AS CHAR) FROM radgroupreply WHERE groupname='%{control:SQL-Group}' AND attribute='Cambium-Canopy-LPDLCIR' ORDER BY id LIMIT 1}" != "") {
                    update reply {
                        Cambium-Canopy-LPDLCIR := "%{sql:SELECT CAST(value AS CHAR) FROM radgroupreply WHERE groupname='%{control:SQL-Group}' AND attribute='Cambium-Canopy-LPDLCIR' ORDER BY id LIMIT 1}"
                    }
                }

                if ("%{sql:SELECT CAST(value AS CHAR) FROM radgroupreply WHERE groupname='%{control:SQL-Group}' AND attribute='Cambium-Canopy-LPULCIR' ORDER BY id LIMIT 1}" != "") {
                    update reply {
                        Cambium-Canopy-LPULCIR := "%{sql:SELECT CAST(value AS CHAR) FROM radgroupreply WHERE groupname='%{control:SQL-Group}' AND attribute='Cambium-Canopy-LPULCIR' ORDER BY id LIMIT 1}"
                    }
                }

                if ("%{sql:SELECT CAST(value AS CHAR) FROM radgroupreply WHERE groupname='%{control:SQL-Group}' AND attribute='Filter-Id' ORDER BY id LIMIT 1}" != "") {
                    update reply {
                        Filter-Id := "%{sql:SELECT CAST(value AS CHAR) FROM radgroupreply WHERE groupname='%{control:SQL-Group}' AND attribute='Filter-Id' ORDER BY id LIMIT 1}"
                    }
                }
            }
        }
        else {
            # No match in any step — Zero Trust reject
            update reply {
                Reply-Message := "Access denied: NAS not authorized for this user"
            }
            reject
        }

    }
    # If NAS-IP-Address is missing, fall through silently (allow default processing)
}
