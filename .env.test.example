# ZeroRadius — Test Environment Defaults
#
# This file documents the NON-SECRET environment variables used when running
# backend tests locally.  It is NOT a secrets file — all values are safe to
# commit and are intended for the in-memory SQLite test harness.
#
# Usage:
#   cp .env.test.example .env.test
#   # (edit .env.test only if you need to override a default)
#
# The test runner (scripts/test-backend-fast.sh) sources this file first
# for defaults, then overlays .env.test if present.
#
# IMPORTANT: These values are for the TEST harness only.  The real .env
# (production / development) is separate and must contain real secrets.

# ---------------------------------------------------------------------------
# Database — overridden by conftest.py to in-memory SQLite; kept here for
# documentation completeness and for any test that reads the variable.
# ---------------------------------------------------------------------------
DATABASE_URL=sqlite+aiosqlite:///:memory:
TEST_DATABASE_URL=sqlite+aiosqlite:///:memory:

# ---------------------------------------------------------------------------
# Security — test-only values (never used in production)
# ---------------------------------------------------------------------------

# Test SECRET_KEY — a fixed, known value so JWTs are reproducible in tests.
# This is intentionally weak and MUST NOT be used outside the test harness.
SECRET_KEY=test-secret-key-not-for-production-use-32chars

# JWT algorithm used in tests (must match what the app expects)
ALGORITHM=HS256

# Token lifetime — generous enough for the entire test session
ACCESS_TOKEN_EXPIRE_MINUTES=60

# CORS — tests run against httpx, so this is informational only
ALLOWED_ORIGINS=http://localhost:3009,http://localhost:5173

# ---------------------------------------------------------------------------
# RADIUS — test server settings (for integration / pyrad tests)
# ---------------------------------------------------------------------------

# Shared secret used by the FreeRADIUS test container / local server
RADIUS_SECRET=testing123

# FreeRADIUS host and ports (defaults for local docker-compose)
RADIUS_HOST=localhost
RADIUS_PORT=1812

# ---------------------------------------------------------------------------
# API Documentation — always disabled in tests
# ---------------------------------------------------------------------------
DISABLE_DOCS=true
